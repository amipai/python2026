import pygame
import random

pygame.init()

WIDTH, HEIGHT = 800, 600
screen = pygame.display.set_mode((WIDTH, HEIGHT))
clock = pygame.time.Clock()

x = WIDTH // 2
y = HEIGHT // 2

vx = random.choice([-3, 3])
vy = random.choice([-3, 3])

running = True
while running:
    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            running = False

    x += vx
    y += vy

    # Bounce off walls
    if x < 0 or x > WIDTH - 50:
        vx *= -1
    if y < 0 or y > HEIGHT - 50:
        vy *= -1

    screen.fill((135, 206, 235))  # Sky blue
    pygame.draw.rect(screen, (255, 105, 180), (x, y, 50, 50))
    pygame.display.flip()
    clock.tick(60)

pygame.quit()
